<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Disables hardened-runtime library validation. Applied to both Debug
	  and Release because the main binary needs to load code signed with a
	  different (or empty) Team ID than its own:
	    - Debug: main binary is signed "AgenticIDE Dev", but Xcode
	      auto-generates AgenticIDE.debug.dylib signed ad-hoc.
	    - Release (CI): main binary is signed "AgenticIDE Release"
	      (self-signed, empty Team ID), but Sparkle.framework's prebuilt
	      SPM xcframework has Sparkle's Team ID baked into its nested
	      binaries (XPC services, Autoupdate, Updater.app) and xcodebuild
	      archive does not deep-resign them.
	  Without this entitlement, dyld rejects the load at launch with
	  "different Team IDs" and the app crashes immediately.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
